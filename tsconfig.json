{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@views/*": ["./src/views/*"],
      "@components/*": ["./src/views/components/*"],
      "@sections/*": ["./src/views/sections/*"],
      "@elements/*": ["./src/views/elements/*"],
      "@assets/*": ["./src/assets/*"],
      "@images/*": ["./src/images/*"],
      "@partials/*": ["./src/partials/*"],
      "@css/*": ["./src/css/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@js/*": ["./src/js/*"],
      "@connectors/*": ["./connectors/*"]
    }
  }
}
